# --- База данных (PostgreSQL) ---
DATABASE_URL=postgresql://username:password@localhost:5432/chess_app
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=chess_db

# --- Безопасность (JWT & Flask) ---
SECRET_KEY=placeholder_for_flask_secret_key
JWT_SECRET_KEY=placeholder_for_jwt_secret_key
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30


# --- Настройки игры ---
STOCKFISH_PATH=/usr/games/stockfish

# --- Настройки сервера ---
FLASK_APP=run.py
FLASK_ENV=production
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://10.120.10.239:5500,http://192.168.1.5:5500
RATELIMIT_STORAGE_URI=memory://

OPENAI_API_KEY=api_key

# --- Roboflow ---
ROBOFLOW_API_KEY=
ROBOFLOW_PROJECT=ctv
ROBOFLOW_VERSION=1

# --- SMS provider ---
SMS_PROVIDER_URL=
SMS_API_KEY=
SMS_SENDER=RO-CHESS

# --- Email (recovery) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- Docker ---
POSTGRES_PASSWORD=change_me